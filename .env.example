# ============================================================
# Variaveis de Ambiente - Agente de E-Commerce
# ============================================================
# 1. Copie este arquivo para .env:
#    Windows : copy .env.example .env
#    Mac/Linux: cp .env.example .env
#
# 2. Preencha os valores abaixo
# 3. NUNCA faca commit do arquivo .env (ja esta no .gitignore)
# ============================================================

# Chave da API do Google Gemini (obrigatoria)
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_aqui

# Modelo Gemini a utilizar
# Opcoes disponiveis e limites do free tier:
#   gemini-2.5-flash        -> 20 req/dia  (mais capaz, recomendado para apresentacao)
#   gemini-2.5-flash-8b     -> 20 req/dia  (versao compacta do 2.5)
#   gemini-2.0-flash        -> 1500 req/dia (bom para testes com mais volume)
#   gemini-2.0-flash-lite   -> 1500 req/dia (mais rapido e economico)
GEMINI_MODEL=gemini-2.5-flash

# Caminho para o banco de dados SQLite
# Coloque o arquivo banco.db dentro da pasta files/
DB_PATH=files/banco.db

# Porta da API FastAPI (apenas para quem usar api.py)
PORT=8000
